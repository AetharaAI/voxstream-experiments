# Copy this to `.env` at the repo root or export these values before running.

VOXTREAM_PROVIDER_HOST=0.0.0.0
VOXTREAM_PROVIDER_PORT=8074
VOXTREAM_PROVIDER_PUBLIC_BASE_URL=http://voxtream-provider:8074
VOXTREAM_PROVIDER_NETWORK_NAME=aether-voice-mesh
VOXTREAM_PROVIDER_TIMEOUT_SECONDS=180
VOXTREAM_PROVIDER_DEFAULT_RESPONSE_FORMAT=wav
VOXTREAM_PROVIDER_GPU_IDS=0
VOXTREAM_PROVIDER_ENABLE_NATIVE_RUNTIME=false

VOXTREAM_MODEL_ALIAS=voxtream_realtime
VOXTREAM_MODEL_ID=herimor/voxtream
VOXTREAM_MODEL_PATH=/mnt/aetherpro/models/voice/herimor/voxtream

VOXTREAM2_MODEL_ALIAS=voxtream2_realtime
VOXTREAM2_MODEL_ID=herimor/voxtream2
VOXTREAM2_MODEL_PATH=/mnt/aetherpro/models/voice/herimor/voxtream2

VOXTREAM_DEVICE=cuda:0
VOXTREAM_DTYPE=float16
VOXTREAM_OUTPUT_DIR=results
VOXTREAM_LOG_DIR=logs
VOXTREAM_DEFAULT_SAMPLE_RATE=24000
VOXTREAM_DEFAULT_VOICE=reference_audio_required

HOST_MODEL_ROOT=/mnt/aetherpro/models
HOST_HF_CACHE_ROOT=/mnt/aetherpro/hf-cache
HF_HOME=/hf-cache
